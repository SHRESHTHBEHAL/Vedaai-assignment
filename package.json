{
  "name": "veda-ai-assessment-creator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev apps/web -p 3000",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "build": "next build apps/web && tsc -p apps/api/tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p apps/api/tsconfig.json",
    "lint": "next lint apps/web",
    "start:api": "tsx apps/api/src/server.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.12.7",
    "@bull-board/express": "^6.12.7",
    "@hookform/resolvers": "^5.2.2",
    "@types/multer": "^2.1.0",
    "@types/ws": "^8.18.1",
    "bullmq": "^5.65.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.8.2",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.468.0",
    "mongoose": "^8.20.1",
    "multer": "^2.1.1",
    "next": "^16.0.7",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
